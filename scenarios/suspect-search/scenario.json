{
  "slug": "suspect-search",
  "name": "Suspect Search",
  "description": "Archive search for persons, bags and helmets using reference images, color/size/position filters, nested search and Qdrant vector indexing.",
  "category": "security",
  "icon": "search",
  "version": "0.1.0",
  "license_feature": "suspect-search",
  "service_url": "http://suspect-search:8091",
  "capabilities": [
    "archive_search",
    "person_attribute_search",
    "object_attribute_search",
    "nested_search",
    "vector_index",
    "onnx_inference",
    "event_producer",
    "reporting",
    "gpu_required"
  ],
  "tabs": ["cameras", "live", "search", "jobs", "events", "reports", "settings"],
  "module_tabs": ["cameras", "live", "search", "jobs", "events", "reports", "settings"],
  "camera_config_schema": {
    "fields": [
      {
        "key": "archive_index_enabled",
        "type": "bool",
        "label": "Archive indexing",
        "default": true
      },
      {
        "key": "object_types",
        "type": "multiselect",
        "label": "Object types",
        "default": ["person", "bag", "helmet"],
        "options": ["person", "bag", "helmet"]
      },
      {
        "key": "min_confidence",
        "type": "number",
        "label": "Minimum confidence",
        "default": 0.72,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    ]
  },
  "event_types": ["suspect_match"],
  "proxy_routes": [
    { "method": "GET", "path": "/health" },
    { "method": "POST", "path": "/health/deep" },
    { "method": "GET", "path": "/reports/summary" },
    { "method": "GET", "path": "/jobs" },
    { "method": "POST", "path": "/jobs/index" },
    { "method": "POST", "path": "/jobs/search" },
    { "method": "GET", "path": "/jobs/{job_id}" },
    { "method": "GET", "path": "/jobs/{job_id}/results" },
    { "method": "DELETE", "path": "/jobs/{job_id}" },
    { "method": "GET", "path": "/results/{result_id}/thumbnail" },
    { "method": "POST", "path": "/results/{result_id}/search-similar" }
  ],
  "resource_requirements": {
    "gpu": "recommended",
    "vram_gb": 8,
    "cpu_cores": 4,
    "memory_gb": 12,
    "storage": "recording thumbnails, Qdrant vectors, optional ONNX model cache",
    "models": ["YOLO26 ONNX detector", "person/object ReID ONNX embedding model"]
  }
}

{
  "slug": "frs",
  "name": "Face Recognition",
  "description": "Detect, recognize and track enrolled faces. Person gallery, groups, photo enrollment, liveness, watchlist alerts, attendance, forensic investigate, transit and cross-camera tour.",
  "category": "security",
  "icon": "scan-face",
  "version": "0.1.0",
  "license_feature": "frs",
  "service_url": "http://frs:8093",
  "capabilities": [
    "person_gallery",
    "face_enrollment",
    "image_recognition",
    "video_jobs",
    "forensic_investigate",
    "transit",
    "attendance",
    "event_producer",
    "reporting",
    "onnx_inference",
    "gpu_required"
  ],
  "tabs": ["cameras", "live", "events", "groups", "persons", "recognize", "investigate", "transit", "attendance", "tour", "reports", "settings"],
  "module_tabs": ["cameras", "live", "events", "groups", "persons", "recognize", "investigate", "transit", "attendance", "tour", "reports", "settings"],
  "camera_config_schema": {
    "fields": [
      {"key": "min_confidence", "type": "float", "label": "Match threshold", "group": "Recognition", "default": 0.6, "min": 0.3, "max": 0.99, "step": 0.01, "help": "Minimum cosine similarity to call a face a known person."},
      {"key": "recognition_enabled", "type": "bool", "label": "Recognition", "group": "Recognition", "default": true, "help": "Match faces against the enrolled gallery."},
      {"key": "detection_enabled", "type": "bool", "label": "Detection only", "group": "Recognition", "default": false, "help": "Emit face-detected events without identifying."},
      {"key": "liveness_enabled", "type": "bool", "label": "Anti-spoof", "group": "Liveness", "default": true},
      {"key": "liveness_threshold", "type": "float", "label": "Liveness threshold", "group": "Liveness", "default": 0.7, "min": 0.3, "max": 0.99, "step": 0.01},
      {"key": "min_face_px", "type": "int", "label": "Min face size (px)", "group": "Quality", "default": 80, "min": 20, "max": 400, "step": 10},
      {"key": "dwell_min_frames", "type": "int", "label": "Dwell frames", "group": "Quality", "default": 5, "min": 1, "max": 30, "step": 1, "help": "Frames a track must persist before an event fires."},
      {"key": "alert_suppress_seconds", "type": "int", "label": "Alert cooldown (s)", "group": "Alerting", "default": 300, "min": 0, "max": 3600, "step": 30, "help": "Minimum gap between repeat alerts for the same person."},
      {"key": "fps", "type": "int", "label": "Analyze FPS", "group": "Stream", "default": 5, "min": 1, "max": 15, "step": 1},
      {"key": "roi", "type": "roi", "label": "Region of interest", "group": "Stream"}
    ]
  },
  "event_types": ["face_recognized", "face_unknown", "spoof_detected", "face_detected"],
  "proxy_routes": [
    { "method": "GET", "path": "/health" },
    { "method": "POST", "path": "/health/deep" },

    { "method": "GET", "path": "/groups" },
    { "method": "POST", "path": "/groups" },
    { "method": "GET", "path": "/groups/{group_id}" },
    { "method": "PUT", "path": "/groups/{group_id}" },
    { "method": "DELETE", "path": "/groups/{group_id}" },

    { "method": "GET", "path": "/persons" },
    { "method": "POST", "path": "/persons" },
    { "method": "GET", "path": "/persons/{person_id}" },
    { "method": "PUT", "path": "/persons/{person_id}" },
    { "method": "DELETE", "path": "/persons/{person_id}" },
    { "method": "POST", "path": "/persons/{person_id}/photos" },
    { "method": "GET", "path": "/persons/{person_id}/photos" },

    { "method": "DELETE", "path": "/photos/{photo_id}" },
    { "method": "GET", "path": "/photos/{photo_id}/image" },

    { "method": "POST", "path": "/recognize-image" },
    { "method": "POST", "path": "/detect-faces" },
    { "method": "GET", "path": "/snapshot" },
    { "method": "POST", "path": "/video-jobs" },
    { "method": "GET", "path": "/video-jobs/{job_id}" },
    { "method": "GET", "path": "/video-jobs/{job_id}/results" },

    { "method": "POST", "path": "/investigate" },
    { "method": "GET", "path": "/tour/timeline/{person_id}" },

    { "method": "POST", "path": "/transit/rules" },
    { "method": "GET", "path": "/transit/rules" },
    { "method": "PUT", "path": "/transit/rules/{rule_id}" },
    { "method": "DELETE", "path": "/transit/rules/{rule_id}" },
    { "method": "GET", "path": "/transit/sessions" },

    { "method": "GET", "path": "/events" },
    { "method": "GET", "path": "/attendance" },
    { "method": "GET", "path": "/attendance/report" },
    { "method": "GET", "path": "/reports/summary" },
    { "method": "GET", "path": "/live" }
  ],
  "resource_requirements": {
    "gpu": "required",
    "vram_gb": 8,
    "cpu_cores": 4,
    "memory_gb": 12,
    "storage": "person photos volume, own Postgres, Qdrant face vectors, optional ONNX model cache",
    "models": ["face detector ONNX", "face embedding (ArcFace) ONNX", "liveness ONNX"]
  }
}

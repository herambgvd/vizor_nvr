  "camera_config_schema": {
    "fields": [
      {
        "key": "min_confidence",
        "type": "float",
        "label": "Match threshold",
        "group": "Recognition",
        "default": 0.5,
        "min": 0.3,
        "max": 0.99,
        "step": 0.01,
        "help": "Minimum face-match similarity (cosine) to call a recognition. Lower catches tilted/far faces but risks false matches; raise toward 0.6 for stricter security. 0.5 balanced."
      },
      {
        "key": "recognition_enabled",
        "type": "bool",
        "label": "Recognition",
        "group": "Recognition",
        "default": true,
        "help": "Match faces against the enrolled gallery."
      },
      {
        "key": "detection_enabled",
        "type": "bool",
        "label": "Detection only",
        "group": "Recognition",
        "default": false,
        "help": "Emit face-detected events without identifying."
      },
      {
        "key": "direction",
        "type": "select",
        "label": "Attendance direction",
        "group": "Recognition",
        "default": "both",
        "options": [
          "both",
          "entry",
          "exit"
        ],
        "help": "Entry camera marks check-in, exit camera marks check-out. 'both' (default) = first-seen/last-seen on a single door."
      },
      {
        "key": "liveness_enabled",
        "type": "bool",
        "label": "Anti-spoof",
        "group": "Liveness",
        "default": true
      },
      {
        "key": "liveness_threshold",
        "type": "float",
        "label": "Liveness threshold",
        "group": "Liveness",
        "default": 0.7,
        "min": 0.3,
        "max": 0.99,
        "step": 0.01
      },
      {
        "key": "det_conf",
        "type": "float",
        "label": "Detector confidence",
        "group": "Quality",
        "default": 0.5,
        "min": 0.2,
        "max": 0.9,
        "step": 0.05,
        "help": "SCRFD face-detector confidence floor."
      },
      {
        "key": "min_face_px",
        "type": "int",
        "label": "Min face size (px)",
        "group": "Quality",
        "default": 28,
        "min": 12,
        "max": 400,
        "step": 4,
        "help": "Smaller = catch far/small faces (lower recognition quality)."
      },
      {
        "key": "min_sharpness",
        "type": "int",
        "label": "Min sharpness",
        "group": "Quality",
        "default": 25,
        "min": 0,
        "max": 200,
        "step": 5,
        "help": "Reject blurry crops (Laplacian variance)."
      },
      {
        "key": "max_pose_deg",
        "type": "int",
        "label": "Max pose (deg)",
        "group": "Quality",
        "default": 60,
        "min": 20,
        "max": 90,
        "step": 5,
        "help": "Reject faces turned more than this (yaw/pitch)."
      },
      {
        "key": "dwell_min_frames",
        "type": "int",
        "label": "Dwell frames",
        "group": "Quality",
        "default": 3,
        "min": 1,
        "max": 30,
        "step": 1,
        "help": "Consecutive frames a face must agree before an event fires. Higher = fewer false positives / jitter, slight delay. 3 recommended."
      },
      {
        "key": "alert_suppress_seconds",
        "type": "int",
        "label": "Alert cooldown (s)",
        "group": "Alerting",
        "default": 300,
        "min": 0,
        "max": 3600,
        "step": 30,
        "help": "Minimum gap between repeat alerts for the same person."
      },
      {
        "key": "fps",
        "type": "int",
        "label": "Analyze FPS",
        "group": "Stream",
        "default": 10,
        "min": 1,
        "max": 15,
        "step": 1,
        "help": "Frames analysed per second. 10+ recommended \u2014 more frames = faster events + steadier recognition (more votes per face). With NVDEC GPU decode the cost is low."
      },
      {
        "key": "roi",
        "type": "roi",
        "label": "Region of interest",
        "group": "Stream"
      }
    ]
  },
  "event_types": [
    "face_recognized",
    "face_unknown",
    "spoof_detected",
    "face_detected",
    "transit_overdue"
  ],

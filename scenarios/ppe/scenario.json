{
  "slug": "ppe",
  "name": "PPE Compliance",
  "description": "Personal protective equipment compliance detection (helmet, vest, mask, gloves, goggles, shoes) for images and recorded video, with per-person verdicts and compliance events.",
  "category": "safety",
  "icon": "hard-hat",
  "version": "0.1.0",
  "license_feature": "ppe",
  "service_url": "http://ppe:8092",
  "capabilities": [
    "image_compliance",
    "pose_detection",
    "video_jobs",
    "onnx_inference",
    "event_producer",
    "reporting",
    "gpu_recommended"
  ],
  "tabs": ["cameras", "live", "ppe_detect", "events", "reports", "settings"],
  "module_tabs": ["cameras", "live", "ppe_detect", "events", "reports", "settings"],
  "camera_config_schema": {
    "fields": [
      {
        "key": "compliance_enabled",
        "type": "bool",
        "label": "PPE compliance",
        "default": true
      },
      {
        "key": "required_items",
        "type": "multiselect",
        "label": "Required PPE",
        "default": ["helmet", "vest"],
        "options": ["helmet", "vest", "mask", "gloves", "goggles", "shoes"]
      },
      {
        "key": "min_confidence",
        "type": "number",
        "label": "Minimum confidence",
        "default": 0.5,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    ]
  },
  "event_types": ["ppe_violation", "ppe_compliant"],
  "proxy_routes": [
    { "method": "GET", "path": "/health" },
    { "method": "POST", "path": "/health/deep" },
    { "method": "POST", "path": "/detect" },
    { "method": "POST", "path": "/detect-pose" },
    { "method": "GET", "path": "/snapshot" },
    { "method": "POST", "path": "/video-jobs" },
    { "method": "GET", "path": "/video-jobs/{job_id}" },
    { "method": "GET", "path": "/video-jobs/{job_id}/results" }
  ],
  "resource_requirements": {
    "gpu": "recommended",
    "vram_gb": 6,
    "cpu_cores": 4,
    "memory_gb": 8,
    "storage": "frame thumbnails, optional ONNX model cache",
    "models": ["PPE detector ONNX (person + PPE items)", "pose estimator ONNX"]
  }
}

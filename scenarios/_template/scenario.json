{
  "slug": "template",
  "name": "Template Scenario",
  "description": "Copy this plugin to start a new AI scenario. Detect -> alert on the shared Triton server.",
  "category": "security",
  "icon": "shield",
  "version": "1.0.0",
  "license_feature": "template",
  "service_url": "http://template:8099",
  "capabilities": ["event_producer", "triton_inference"],
  "tabs": ["cameras", "info"],
  "module_tabs": ["cameras", "info"],
  "camera_config_schema": {
    "fields": [
      {
        "key": "enabled",
        "type": "bool",
        "label": "Enable analysis",
        "default": true
      },
      {
        "key": "min_confidence",
        "type": "number",
        "label": "Minimum confidence",
        "default": 0.5,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    ]
  },
  "event_types": ["template_detected"],
  "proxy_routes": [
    { "method": "GET", "path": "/health" },
    { "method": "GET", "path": "/info" }
  ],
  "resource_requirements": {
    "gpu": "recommended",
    "vram_gb": 4,
    "cpu_cores": 2,
    "memory_gb": 4,
    "models": ["one Triton detector model"]
  }
}

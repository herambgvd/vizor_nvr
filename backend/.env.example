# =============================================================================
# Vizor NVR v2.0 — Environment Configuration
# =============================================================================
# Copy to .env and adjust values for your deployment.
# =============================================================================

# ── Database ────────────────────────────────────────────────────────
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://nvr:password@localhost:5432/nvr_db
#
# Leave empty to fall back to SQLite (dev/testing):
DATABASE_URL=

# ── JWT / Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3006

# ── Storage Paths ───────────────────────────────────────────────────
STORAGE_PATH=./data/recordings
THUMBNAIL_PATH=./data/thumbnails
HLS_PATH=./data/hls
EXPORT_PATH=./data/exports

# ── go2rtc ──────────────────────────────────────────────────────────
GO2RTC_URL=http://localhost:1984
GO2RTC_RTSP_PORT=8554

# ── Recording ───────────────────────────────────────────────────────
DEFAULT_SEGMENT_DURATION=900

# ── FFmpeg ──────────────────────────────────────────────────────────
FFMPEG_RECOVERY_ENABLED=true

# ── ONVIF Device Server (NVR as ONVIF device) ───────────────────────
ONVIF_XADDR_HOST=                    # External host/IP advertised to VMS (auto-detected if empty)
ONVIF_DEVICE_USERNAME=admin
ONVIF_DEVICE_PASSWORD=admin

# ── Redis (optional — recommended for production rate-limiting) ─────
REDIS_URL=

# ── go2rtc CORS / WebRTC candidates (used by generate-go2rtc-config.py)
NVR_PUBLIC_HOST=192.168.1.100
GO2RTC_API_ORIGIN=http://localhost
GO2RTC_CANDIDATES=192.168.1.100:8555,127.0.0.1:8555

# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENV=development

# ── Cluster (N+1 Hot Standby) ───────────────────────────────────────
# NVR_NODE_ID: unique name for this node (default: hostname)
NVR_NODE_ID=
# NVR_NODE_IP: IP advertised to other cluster nodes
NVR_NODE_IP=
# Heartbeat interval in seconds (how often each node tries to acquire leadership)
CLUSTER_HEARTBEAT_INTERVAL=5
# Advisory lock TTL in seconds (standby takes over if leader misses this)
CLUSTER_LEASE_TTL=15

# ── POS / ATM Text Overlay ──────────────────────────────────────────
# TCP port for receipt-printer serial-over-IP devices
# Default 9100 (same as raw-print protocol) — change if there is a conflict
POS_OVERLAY_PORT=9100
POS_OVERLAY_HOST=0.0.0.0
# Maximum message size before the connection is closed (bytes)
POS_MAX_MESSAGE_BYTES=4096
# How many messages to buffer per source IP when no camera is mapped yet
POS_BUFFER_LAST_N=20
# IP-to-camera mapping: POS_CAM_<IP_WITH_UNDERSCORES>=<camera-uuid>
# POS_CAM_192_168_1_50=3a4f9d2c-1234-5678-abcd-ef0123456789

# ── ANR (Automatic Network Replenishment) ───────────────────────────
# How long a camera must be continuously online before ANR is triggered (seconds)
ANR_DEBOUNCE_SECONDS=60
# Segment size for each ANR download chunk (seconds)
ANR_SEGMENT_DURATION=600
# Maximum concurrent ANR download jobs (bandwidth throttle)
ANR_MAX_CONCURRENT_JOBS=2

# ── Dewarp (fisheye 360° cameras) ───────────────────────────────────
# Maximum simultaneous dewarp FFmpeg jobs (CPU guard)
DEWARP_MAX_CONCURRENT=4
# Fallback output resolution when no GPU encoder is available
DEWARP_FALLBACK_WIDTH=1280
DEWARP_FALLBACK_HEIGHT=720

# ── RAID (Linux + mdadm only) ───────────────────────────────────────
# Seconds between RAID degraded-state polls
RAID_POLL_INTERVAL=60

# ── Archive / Scheduled Backup ──────────────────────────────────────
# How often to evaluate cron schedules (seconds)
ARCHIVE_CHECK_INTERVAL=60
# Maximum NAS-unreachable backoff (seconds); default 960 = 16 minutes
ARCHIVE_NAS_MAX_BACKOFF=960

# ── Twilio (SMS + WhatsApp alerts) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+12015551234
# WhatsApp-approved business number (register at twilio.com/console/sms/whatsapp/learn)
TWILIO_WHATSAPP_FROM=+14155551234
# Rate limits (per recipient, per hour) — billing guard
SMS_RATE_LIMIT_PER_HOUR=5
WA_RATE_LIMIT_PER_HOUR=5

# ── FFmpeg Governor ─────────────────────────────────────────────────
# Maximum concurrent FFmpeg processes across all services (default 192)
FFMPEG_GLOBAL_PROCESS_CAP=192
# Hardware encoder: auto | nvenc | vaapi | videotoolbox | software
HARDWARE_TRANSCODING=auto

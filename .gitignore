# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment files (comprehensive coverage)

*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/
.venv-*/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db
backend/data/
**/*.db
**/*.db-*
**/*.sqlite
**/*.sqlite3
**/*.sqlite3-*
scripts/license_web/*.sqlite*
scripts/license_web/.venv/
scripts/license_web/__pycache__/

# go2rtc runtime config — seeded from go2rtc.yaml.template by scripts/seed-go2rtc-config.sh
# The file must exist before `docker compose up` (bind-mount); run `make up` or
# `bash scripts/seed-go2rtc-config.sh` to create it.  NEVER commit after go2rtc
# mutates it with discovered stream entries.
go2rtc.yaml

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Environment files
*.env
*.env.*
!frontend/.env
!frontend/.env.example
!backend/.env.example

# SOPS / age — encrypted secrets ARE committed (they're encrypted).
# Plaintext .env files must NEVER be committed (already covered above by *.env).
# Re-allow SOPS-encrypted files so the *.env rule doesn't catch them:
!*.sops.env
!*.sops.yaml
!*.sops.yml
!*.sops.json
!.sops.yaml

# Age private keys MUST NEVER be committed
keys.txt
age-key.txt
*.age
age/keys*

# Vendor signing keys + customer licenses
vendor-keys/
*.lic
data/.machine_id
deepstream/model_repository/**/*.onnx
deepstream/model_repository/**/*.engine
deepstream/model_repository/**/*.plan

# AI scenario ONNX model weights (large binaries — fetched via scripts/fetch-frs-models.sh)
models/*.onnx
models/**/*.onnx

# Triton model repository — large ONNX weights + generated configs (not in git;
# ONNX fetched/exported separately, config.pbtxt regenerated per deploy).
triton/model_repository/**/*.onnx
triton/model_repository/**/*.engine
triton/model_repository/**/*.plan

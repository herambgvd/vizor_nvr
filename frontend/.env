# Frontend build-time URLs.
#
# Empty defaults = same-origin: the SPA talks to whatever host serves it
# (i.e. nginx at https://localhost/). Same-origin avoids CORS preflights
# and mixed-content warnings.
#
# Override only when running the CRA dev server on a different origin
# than the backend (e.g. local dev with `npm start` on :3000 and
# backend on :8000).

REACT_APP_BACKEND_URL=
REACT_APP_API_URL=/api
REACT_APP_GO2RTC_URL=/go2rtc

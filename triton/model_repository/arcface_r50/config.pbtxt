# ArcFace R50 512-d face embedder, re-exported with a dynamic batch axis so
# Triton DYNAMIC BATCHING coalesces per-face embed requests from all cameras
# into GPU batches — the throughput win at many-camera scale. With max_batch_size
# the batch dim is implicit, so dims here exclude it.
name: "arcface_r50"
platform: "onnxruntime_onnx"
max_batch_size: 16
input [
  { name: "input.1" data_type: TYPE_FP32 dims: [ 3, 112, 112 ] }
]
output [
  { name: "683" data_type: TYPE_FP32 dims: [ 512 ] }
]
instance_group [ { count: 2 kind: KIND_GPU } ]
dynamic_batching {
  preferred_batch_size: [ 4, 8, 16 ]
  max_queue_delay_microseconds: 2000
}

# PPE detector (YOLO26n @1280) — TensorRT FP16 engine. Same graph as ppe_yolo26
# but compiled to a TensorRT plan for ~10x faster inference (GPU compute ~3.5 ms
# vs ~65 ms for the ONNX runtime path) at the same accuracy. The .plan is built
# with trtexec --fp16 from 1/model.onnx and is GPU/TensorRT-version specific, so
# it is NOT committed — rebuild on the target box (see README).
# NMS baked into the export -> [1,300,6] (x1,y1,x2,y2,score,class).
name: "ppe_yolo26_trt"
platform: "tensorrt_plan"
max_batch_size: 0
input [
  { name: "images" data_type: TYPE_FP32 dims: [ 1, 3, 1280, 1280 ] }
]
output [
  { name: "output0" data_type: TYPE_FP32 dims: [ 1, 300, 6 ] }
]
instance_group [ { count: 1 kind: KIND_GPU } ]

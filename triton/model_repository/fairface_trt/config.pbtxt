# fairface — TensorRT FP16 face-attribute engine.
name: "fairface_trt"
platform: "tensorrt_plan"
max_batch_size: 0
input [ { name: "input" data_type: TYPE_FP32 dims: [ 1, 3, 224, 224 ] } ]
output [ { name: "output" data_type: TYPE_FP32 dims: [ 1, 18 ] } ]
instance_group [ { count: 1 kind: KIND_GPU } ]

# DINOv2-small backbone (facebook/dinov2-small) — outputs the 384-d CLS embedding
# used by the PPE second-stage helmet/vest verifier. The plugin standardizes the
# embedding + applies the tiny linear heads (vit_ppe_dinov2_small.npz) client-side.
# Input: imagenet-normalized 224x224 RGB. Dynamic batch.
name: "dinov2_small"
platform: "onnxruntime_onnx"
max_batch_size: 16
input [
  { name: "pixel_values" data_type: TYPE_FP32 dims: [ 3, 224, 224 ] }
]
output [
  { name: "cls" data_type: TYPE_FP32 dims: [ 384 ] }
]
dynamic_batching { preferred_batch_size: [ 4, 8 ] max_queue_delay_microseconds: 3000 }
instance_group [ { count: 1 kind: KIND_GPU } ]

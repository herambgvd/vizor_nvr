# ArcFace face embedding — 512-d vector → Qdrant similarity search.

name: "arcface"
platform: "onnxruntime_onnx"
max_batch_size: 16

input [
  {
    name: "input.1"
    data_type: TYPE_FP32
    dims: [ 3, 112, 112 ]
  }
]

output [
  {
    name: "683"
    data_type: TYPE_FP32
    dims: [ 512 ]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_GPU
  }
]

dynamic_batching {
  preferred_batch_size: [ 1, 8 ]
  max_queue_delay_microseconds: 5000
}

optimization {
  execution_accelerators {
    gpu_execution_accelerator: [ { name: "tensorrt" } ]
  }
}

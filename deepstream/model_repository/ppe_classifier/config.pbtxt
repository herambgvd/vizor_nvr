# PPE multi-label classifier (SGIE) — runs on each person crop from PGIE.
# Output: sigmoid scores for 6 PPE items. Caller compares against
# camera's `required_items` to emit violations.

name: "ppe_classifier"
platform: "onnxruntime_onnx"
max_batch_size: 16

input [
  {
    name: "input"
    data_type: TYPE_FP32
    dims: [ 3, 224, 224 ]
  }
]

output [
  {
    name: "output"
    data_type: TYPE_FP32
    dims: [ 6 ]   # helmet, vest, mask, gloves, goggles, boots
  }
]

instance_group [
  {
    count: 1
    kind: KIND_GPU
  }
]

dynamic_batching {
  preferred_batch_size: [ 1, 8 ]
  max_queue_delay_microseconds: 5000
}

optimization {
  execution_accelerators {
    gpu_execution_accelerator: [ { name: "tensorrt" } ]
  }
}
